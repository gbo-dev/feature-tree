#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=""
GIT_COMMON_DIR=""
DEFAULT_BRANCH=""
INCLUDE_FILE=""

WORKTREE_BRANCHES=()
WORKTREE_PATHS=()

die() {
  printf 'wt: %s\n' "$1" >&2
  exit 1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

git_common() {
  git --git-dir="$GIT_COMMON_DIR" "$@"
}

detect_default_branch() {
  local remote_head=""

  remote_head="$(git_common symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [[ -n "$remote_head" ]]; then
    printf '%s' "${remote_head#origin/}"
    return
  fi

  if git_common show-ref --verify --quiet refs/heads/main; then
    printf '%s' "main"
    return
  fi

  if git_common show-ref --verify --quiet refs/heads/master; then
    printf '%s' "master"
    return
  fi

  if git_common show-ref --verify --quiet refs/heads/trunk; then
    printf '%s' "trunk"
    return
  fi

  printf '%s' "main"
}

init_context() {
  local common=""
  local is_bare=""

  common="$(git rev-parse --git-common-dir 2>/dev/null || true)"
  [[ -n "$common" ]] || die "not inside a git worktree"
  [[ -d "$common" ]] || die "git common dir not found: $common"

  GIT_COMMON_DIR="$(cd "$common" && pwd -P)"
  REPO_ROOT="$(cd "$GIT_COMMON_DIR/.." && pwd -P)"

  [[ "$(basename "$GIT_COMMON_DIR")" == ".git" ]] || die "expected .git common dir, found: $GIT_COMMON_DIR"

  is_bare="$(git_common rev-parse --is-bare-repository 2>/dev/null || true)"
  [[ "$is_bare" == "true" ]] || die "only bare-in-.git repositories are supported"

  DEFAULT_BRANCH="$(detect_default_branch)"
  INCLUDE_FILE=".worktreeinclude"
}

sanitize_branch_name() {
  local value="$1"
  value="${value//\//-}"
  value="${value//\\/-}"
  printf '%s' "$value"
}

current_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || true
}

resolve_branch_shortcut() {
  local branch="$1"
  local current=""

  case "$branch" in
    '^')
      printf '%s' "$DEFAULT_BRANCH"
      ;;
    '@')
      current="$(current_branch)"
      [[ -n "$current" ]] || die "HEAD is detached; @ is unavailable"
      printf '%s' "$current"
      ;;
    *)
      printf '%s' "$branch"
      ;;
  esac
}

collect_worktrees() {
  local line=""
  local entry_path=""
  local entry_branch=""

  WORKTREE_BRANCHES=()
  WORKTREE_PATHS=()

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$line" ]]; then
      if [[ -n "$entry_path" && -n "$entry_branch" ]]; then
        WORKTREE_BRANCHES+=("$entry_branch")
        WORKTREE_PATHS+=("$entry_path")
      fi
      entry_path=""
      entry_branch=""
      continue
    fi

    case "$line" in
      'worktree '*)
        entry_path="${line#worktree }"
        ;;
      'branch refs/heads/'*)
        entry_branch="${line#branch refs/heads/}"
        ;;
      *)
        ;;
    esac
  done < <(git_common worktree list --porcelain)

  if [[ -n "$entry_path" && -n "$entry_branch" ]]; then
    WORKTREE_BRANCHES+=("$entry_branch")
    WORKTREE_PATHS+=("$entry_path")
  fi
}

find_worktree_path() {
  local branch="$1"
  local i=0

  for ((i = 0; i < ${#WORKTREE_BRANCHES[@]}; i++)); do
    if [[ "${WORKTREE_BRANCHES[$i]}" == "$branch" ]]; then
      printf '%s' "${WORKTREE_PATHS[$i]}"
      return 0
    fi
  done

  return 1
}

branch_exists_local() {
  local branch="$1"
  git_common show-ref --verify --quiet "refs/heads/${branch}"
}

require_existing_worktree_path() {
  local branch="$1"
  local path=""

  path="$(find_worktree_path "$branch" || true)"
  [[ -n "$path" ]] || die "no worktree found for branch '$branch'"
  printf '%s' "$path"
}

compute_branch_relation() {
  local branch="$1"
  local counts=""
  local behind=""
  local ahead=""

  if [[ "$branch" == "$DEFAULT_BRANCH" ]]; then
    printf '%s' "-"
    return
  fi

  counts="$(git_common rev-list --left-right --count "${DEFAULT_BRANCH}...${branch}" 2>/dev/null || true)"
  [[ -n "$counts" ]] || {
    printf '%s' "?"
    return
  }

  behind="${counts%%[[:space:]]*}"
  ahead="${counts##*[[:space:]]}"
  printf '↑%s ↓%s' "$ahead" "$behind"
}

compute_dirty_symbols() {
  local path="$1"
  local line=""
  local staged=0
  local unstaged=0
  local untracked=0
  local x=""
  local y=""
  local result=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" ]] && continue
    if [[ "$line" == '?? '* ]]; then
      untracked=1
      continue
    fi

    x="${line:0:1}"
    y="${line:1:1}"
    [[ "$x" != ' ' ]] && staged=1
    [[ "$y" != ' ' ]] && unstaged=1
  done < <(git -C "$path" status --porcelain --untracked-files=normal 2>/dev/null || true)

  [[ $staged -eq 1 ]] && result+="+"
  [[ $unstaged -eq 1 ]] && result+="!"
  [[ $untracked -eq 1 ]] && result+="?"

  if [[ -z "$result" ]]; then
    printf '%s' "clean"
  else
    printf '%s' "$result"
  fi
}

is_worktree_clean() {
  local path="$1"
  local status=""
  status="$(git -C "$path" status --porcelain --untracked-files=normal 2>/dev/null || true)"
  [[ -z "$status" ]]
}

worktree_upstream_ref() {
  local path="$1"
  git -C "$path" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true
}

ensure_worktree_safe_to_remove() {
  local path="$1"
  local branch="$2"
  local target_ref="$3"
  local upstream=""
  local ahead=""

  is_worktree_clean "$path" || die "worktree is dirty: $path (commit/stash/remove changes first, or use --force-worktree)"

  upstream="$(worktree_upstream_ref "$path")"
  if [[ -z "$upstream" ]]; then
    branch_deletable "$branch" "$target_ref" && return 0
    die "branch '$branch' has no upstream tracking branch and differs from $target_ref; push first, or use --force-worktree"
  fi

  ahead="$(git -C "$path" rev-list --count "${upstream}..HEAD" 2>/dev/null || true)"
  if [[ ! "$ahead" =~ ^[0-9]+$ ]]; then
    die "failed to compare branch '$branch' to upstream '$upstream'"
  fi

  if ((ahead > 0)); then
    branch_deletable "$branch" "$target_ref" && return 0
    die "branch '$branch' has commits not pushed to $upstream; push first, or use --force-worktree"
  fi
}

emit_cd() {
  local path="$1"
  if [[ "${WT_EMIT_CD:-0}" == "1" ]]; then
    printf '__WT_CD__=%s\n' "$path"
  fi
}

copy_manifest_between_paths() {
  local src_path="$1"
  local dst_path="$2"
  local manifest_path=""
  local raw=""
  local pattern=""
  local matched=0
  local copied=0
  local match=""
  local rel=""
  local dest=""
  local -a matches=()

  [[ "$src_path" != "$dst_path" ]] || {
    printf 'copy-include: source and destination are the same, skipping\n'
    return 0
  }

  manifest_path="${src_path}/${INCLUDE_FILE}"
  if [[ ! -f "$manifest_path" ]]; then
    printf 'copy-include: include file not found at %s\n' "$manifest_path"
    return 0
  fi

  shopt -s nullglob dotglob

  while IFS= read -r raw || [[ -n "$raw" ]]; do
    pattern="${raw%%#*}"
    pattern="$(trim "$pattern")"
    [[ -z "$pattern" ]] && continue
    pattern="${pattern#/}"

    matches=("${src_path}"/${pattern})
    if [[ ${#matches[@]} -eq 0 ]]; then
      continue
    fi

    for match in "${matches[@]}"; do
      matched=1
      rel="${match#${src_path}/}"
      [[ "$rel" != "$match" ]] || continue

      dest="${dst_path}/${rel}"
      if [[ -d "$match" && ! -L "$match" ]]; then
        mkdir -p "$dest"
        cp -a "$match"/. "$dest"/
      else
        mkdir -p "$(dirname "$dest")"
        cp -a "$match" "$dest"
      fi
      copied=$((copied + 1))
    done
  done < "$manifest_path"

  shopt -u nullglob dotglob

  if [[ $matched -eq 0 ]]; then
    printf 'copy-include: no entries matched from %s\n' "$manifest_path"
    return 0
  fi

  printf 'copy-include: copied %d paths from %s to %s\n' "$copied" "$src_path" "$dst_path"
}

copy_include_between_branches() {
  local from_branch="$1"
  local to_branch="$2"
  local src_path=""
  local dst_path=""

  src_path="$(require_existing_worktree_path "$from_branch")"
  dst_path="$(require_existing_worktree_path "$to_branch")"

  copy_manifest_between_paths "$src_path" "$dst_path"
}

pick_worktree_branch_interactive() {
  local i=0
  local current=""
  local line=""
  local selected=""
  local selection=""

  [[ ${#WORKTREE_BRANCHES[@]} -gt 0 ]] || die "no worktrees available"

  current="$(current_branch)"

  if command -v fzf >/dev/null 2>&1; then
    selected="$({
      for ((i = 0; i < ${#WORKTREE_BRANCHES[@]}; i++)); do
        line="${WORKTREE_BRANCHES[$i]}"
        if [[ "$line" == "$current" ]]; then
          printf '* %s\t%s\n' "$line" "${WORKTREE_PATHS[$i]}"
        else
          printf '  %s\t%s\n' "$line" "${WORKTREE_PATHS[$i]}"
        fi
      done
    } | fzf --prompt='switch> ' --delimiter=$'\t' --with-nth=1,2 || true)"

    [[ -n "$selected" ]] || die "selection cancelled"
    selected="${selected#\* }"
    selected="${selected#  }"
    printf '%s' "${selected%%$'\t'*}"
    return
  fi

  [[ -t 0 ]] || die "fzf not found and no TTY for numeric picker"

  printf 'Select worktree:\n' >&2
  for ((i = 0; i < ${#WORKTREE_BRANCHES[@]}; i++)); do
    printf '  %2d) %s  %s\n' "$((i + 1))" "${WORKTREE_BRANCHES[$i]}" "${WORKTREE_PATHS[$i]}" >&2
  done

  printf 'Number: ' >&2
  IFS= read -r selection
  [[ "$selection" =~ ^[0-9]+$ ]] || die "invalid selection"
  ((selection >= 1 && selection <= ${#WORKTREE_BRANCHES[@]})) || die "selection out of range"

  printf '%s' "${WORKTREE_BRANCHES[$((selection - 1))]}"
}

pick_worktree_branch_for_remove_interactive() {
  local i=0
  local current=""
  local branch=""
  local path=""
  local dirty=""
  local relation=""
  local selected=""
  local selection=""
  local -a branches=()
  local -a paths=()

  [[ ${#WORKTREE_BRANCHES[@]} -gt 0 ]] || die "no worktrees available"

  for ((i = 0; i < ${#WORKTREE_BRANCHES[@]}; i++)); do
    branch="${WORKTREE_BRANCHES[$i]}"
    if [[ "$branch" == "$DEFAULT_BRANCH" ]]; then
      continue
    fi
    branches+=("$branch")
    paths+=("${WORKTREE_PATHS[$i]}")
  done

  [[ ${#branches[@]} -gt 0 ]] || die "no removable worktrees available"

  current="$(current_branch)"

  if command -v fzf >/dev/null 2>&1; then
    selected="$({
      for ((i = 0; i < ${#branches[@]}; i++)); do
        branch="${branches[$i]}"
        path="${paths[$i]}"
        dirty="$(compute_dirty_symbols "$path")"
        relation="$(compute_branch_relation "$branch")"

        if [[ "$branch" == "$current" ]]; then
          printf '* %s\t%s\t%s\t%s\n' "$branch" "$path" "$dirty" "$relation"
        else
          printf '  %s\t%s\t%s\t%s\n' "$branch" "$path" "$dirty" "$relation"
        fi
      done
    } | fzf --prompt='remove> ' --delimiter=$'\t' --with-nth=1,2,3,4 || true)"

    [[ -n "$selected" ]] || die "selection cancelled"
    selected="${selected#\* }"
    selected="${selected#  }"
    printf '%s' "${selected%%$'\t'*}"
    return
  fi

  [[ -t 0 ]] || die "fzf not found and no TTY for numeric picker"

  printf 'Select worktree to remove:\n' >&2
  for ((i = 0; i < ${#branches[@]}; i++)); do
    dirty="$(compute_dirty_symbols "${paths[$i]}")"
    relation="$(compute_branch_relation "${branches[$i]}")"
    printf '  %2d) %s  %s  [%s]  (%s)\n' "$((i + 1))" "${branches[$i]}" "${paths[$i]}" "$dirty" "$relation" >&2
  done

  printf 'Number: ' >&2
  IFS= read -r selection
  [[ "$selection" =~ ^[0-9]+$ ]] || die "invalid selection"
  ((selection >= 1 && selection <= ${#branches[@]})) || die "selection out of range"

  printf '%s' "${branches[$((selection - 1))]}"
}

ensure_unique_worktree_path() {
  local branch="$1"
  local new_path="$2"
  local i=0

  for ((i = 0; i < ${#WORKTREE_BRANCHES[@]}; i++)); do
    if [[ "${WORKTREE_PATHS[$i]}" == "$new_path" && "${WORKTREE_BRANCHES[$i]}" != "$branch" ]]; then
      die "path collision: '$branch' maps to ${new_path}, already used by '${WORKTREE_BRANCHES[$i]}'"
    fi
  done
}

create_worktree_internal() {
  local branch="$1"
  local base_branch="$2"
  local safe_branch=""
  local worktree_path=""
  local existing_path=""
  local from_branch=""

  [[ -n "$branch" ]] || die "branch name is required"

  collect_worktrees
  existing_path="$(find_worktree_path "$branch" || true)"
  if [[ -n "$existing_path" ]]; then
    emit_cd "$existing_path"
    printf 'Already exists: %s (%s)\n' "$branch" "$existing_path"
    return 0
  fi

  safe_branch="$(sanitize_branch_name "$branch")"
  worktree_path="${REPO_ROOT}/${safe_branch}"

  ensure_unique_worktree_path "$branch" "$worktree_path"
  [[ ! -e "$worktree_path" ]] || die "target path already exists: $worktree_path"

  if branch_exists_local "$branch"; then
    git_common worktree add "$worktree_path" "$branch"
  else
    branch_exists_local "$base_branch" || die "base branch not found locally: $base_branch"
    git_common worktree add -b "$branch" "$worktree_path" "$base_branch"
  fi

  collect_worktrees
  from_branch="$DEFAULT_BRANCH"
  if [[ "$from_branch" != "$branch" ]]; then
    copy_include_between_branches "$from_branch" "$branch"
  fi

  emit_cd "$worktree_path"
  printf 'Created worktree: %s -> %s\n' "$branch" "$worktree_path"
}

deletion_target_ref() {
  local upstream=""
  local ahead=0

  upstream="$(git_common for-each-ref --format='%(upstream:short)' "refs/heads/${DEFAULT_BRANCH}" | head -n 1)"
  if [[ -n "$upstream" ]]; then
    ahead="$(git_common rev-list --count "${DEFAULT_BRANCH}..${upstream}" 2>/dev/null || printf '0')"
    if [[ "$ahead" =~ ^[0-9]+$ ]] && ((ahead > 0)); then
      printf '%s' "$upstream"
      return
    fi
  fi

  printf '%s' "$DEFAULT_BRANCH"
}

branch_deletable() {
  local branch="$1"
  local target="$2"
  local branch_tree=""
  local target_tree=""

  if git_common merge-base --is-ancestor "$branch" "$target" >/dev/null 2>&1; then
    return 0
  fi

  if git_common diff --quiet "${target}...${branch}" >/dev/null 2>&1; then
    return 0
  fi

  branch_tree="$(git_common rev-parse "refs/heads/${branch}^{tree}" 2>/dev/null || true)"
  target_tree="$(git_common rev-parse "${target}^{tree}" 2>/dev/null || true)"
  if [[ -n "$branch_tree" && -n "$target_tree" && "$branch_tree" == "$target_tree" ]]; then
    return 0
  fi

  return 1
}

worktree_lock_reason() {
  local path="$1"
  local line=""
  local entry_path=""
  local entry_lock=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$line" ]]; then
      if [[ "$entry_path" == "$path" ]]; then
        printf '%s' "$entry_lock"
        return 0
      fi
      entry_path=""
      entry_lock=""
      continue
    fi

    case "$line" in
      'worktree '*)
        entry_path="${line#worktree }"
        ;;
      'locked')
        entry_lock="locked"
        ;;
      'locked '*)
        entry_lock="${line#locked }"
        ;;
      *)
        ;;
    esac
  done < <(git_common worktree list --porcelain)

  if [[ "$entry_path" == "$path" ]]; then
    printf '%s' "$entry_lock"
    return 0
  fi

  return 1
}

cmd_switch() {
  local branch=""
  local create_flag=0
  local base_branch=""
  local path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -c|--create)
        create_flag=1
        shift
        ;;
      -b|--base)
        [[ $# -ge 2 ]] || die "--base requires a value"
        base_branch="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: wt switch [--create] [--base <branch>] [branch]\n'
        return 0
        ;;
      -* )
        die "unknown option: $1"
        ;;
      *)
        [[ -z "$branch" ]] || die "unexpected argument: $1"
        branch="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$branch" ]]; then
    collect_worktrees
    branch="$(pick_worktree_branch_interactive)"
  fi

  branch="$(resolve_branch_shortcut "$branch")"
  if [[ -n "$base_branch" ]]; then
    base_branch="$(resolve_branch_shortcut "$base_branch")"
  fi

  collect_worktrees
  path="$(find_worktree_path "$branch" || true)"
  if [[ -n "$path" ]]; then
    emit_cd "$path"
    printf 'Switched to %s (%s)\n' "$branch" "$path"
    return 0
  fi

  if [[ $create_flag -eq 1 ]]; then
    create_worktree_internal "$branch" "${base_branch:-$DEFAULT_BRANCH}"
    return 0
  fi

  die "branch '$branch' has no worktree (use wt create $branch or wt switch --create $branch)"
}

cmd_create() {
  local branch=""
  local base_branch="$DEFAULT_BRANCH"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -b|--base)
        [[ $# -ge 2 ]] || die "--base requires a value"
        base_branch="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: wt create <branch> [--base <branch>]\n'
        return 0
        ;;
      -* )
        die "unknown option: $1"
        ;;
      *)
        [[ -z "$branch" ]] || die "unexpected argument: $1"
        branch="$1"
        shift
        ;;
    esac
  done

  [[ -n "$branch" ]] || die "branch name is required"
  base_branch="$(resolve_branch_shortcut "$base_branch")"

  create_worktree_internal "$branch" "$base_branch"
}

cmd_list() {
  local i=0
  local marker=""
  local branch=""
  local path=""
  local dirty=""
  local relation=""
  local current=""

  collect_worktrees
  current="$(current_branch)"

  printf '%-2s %-28s %-46s %-8s %-14s\n' "" "BRANCH" "PATH" "DIRTY" "VS ${DEFAULT_BRANCH}"
  for ((i = 0; i < ${#WORKTREE_BRANCHES[@]}; i++)); do
    branch="${WORKTREE_BRANCHES[$i]}"
    path="${WORKTREE_PATHS[$i]}"

    marker=" "
    if [[ "$branch" == "$current" ]]; then
      marker="@"
    elif [[ "$branch" == "$DEFAULT_BRANCH" ]]; then
      marker="^"
    fi

    dirty="$(compute_dirty_symbols "$path")"
    relation="$(compute_branch_relation "$branch")"
    printf '%-2s %-28s %-46s %-8s %-14s\n' "$marker" "$branch" "$path" "$dirty" "$relation"
  done
}

cmd_copy_include() {
  local from_branch="$DEFAULT_BRANCH"
  local to_branch=""
  local current=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)
        [[ $# -ge 2 ]] || die "--from requires a branch"
        from_branch="$2"
        shift 2
        ;;
      --to)
        [[ $# -ge 2 ]] || die "--to requires a branch"
        to_branch="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: wt copy-include [--from <branch>] [--to <branch>]\n'
        return 0
        ;;
      -* )
        die "unknown option: $1"
        ;;
      *)
        die "unexpected argument: $1"
        ;;
    esac
  done

  if [[ -z "$to_branch" ]]; then
    current="$(current_branch)"
    [[ -n "$current" ]] || die "cannot infer destination branch from detached HEAD"
    to_branch="$current"
  fi

  from_branch="$(resolve_branch_shortcut "$from_branch")"
  to_branch="$(resolve_branch_shortcut "$to_branch")"
  collect_worktrees

  copy_include_between_branches "$from_branch" "$to_branch"
}

cmd_remove() {
  local branch=""
  local force_worktree=0
  local force_branch=0
  local no_delete_branch=0
  local path=""
  local current=""
  local fallback_path=""
  local target_ref=""
  local lock_reason=""
  local remove_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force-worktree|--force)
        force_worktree=1
        shift
        ;;
      -D|--force-branch|--force-delete)
        force_branch=1
        shift
        ;;
      --no-delete-branch)
        no_delete_branch=1
        shift
        ;;
      -h|--help)
        printf 'Usage: wt remove [branch] [-f|--force-worktree] [-D|--force-branch] [--no-delete-branch]\n'
        return 0
        ;;
      -* )
        die "unknown option: $1"
        ;;
      *)
        [[ -z "$branch" ]] || die "unexpected argument: $1"
        branch="$1"
        shift
        ;;
    esac
  done

  if [[ $no_delete_branch -eq 1 && $force_branch -eq 1 ]]; then
    die "cannot use --force-branch with --no-delete-branch"
  fi

  if [[ -z "$branch" ]]; then
    current="$(current_branch)"
    [[ -n "$current" ]] || die "cannot infer branch from detached HEAD"

    if [[ "$current" != "$DEFAULT_BRANCH" ]]; then
      branch="$current"
    elif [[ -t 0 ]]; then
      collect_worktrees
      branch="$(pick_worktree_branch_for_remove_interactive)"
    else
      branch="$current"
    fi
  fi

  branch="$(resolve_branch_shortcut "$branch")"
  collect_worktrees

  path="$(find_worktree_path "$branch" || true)"
  [[ -n "$path" ]] || die "no worktree found for branch '$branch'"

  if [[ "$branch" == "$DEFAULT_BRANCH" ]]; then
    die "refusing to remove default branch worktree '$DEFAULT_BRANCH'"
  fi

  lock_reason="$(worktree_lock_reason "$path" || true)"
  if [[ -n "$lock_reason" ]]; then
    die "worktree is locked: $path (${lock_reason})"
  fi

  current="$(current_branch)"
  if [[ "$current" == "$branch" ]]; then
    fallback_path="$(find_worktree_path "$DEFAULT_BRANCH" || true)"
    [[ -n "$fallback_path" ]] || die "default branch worktree '$DEFAULT_BRANCH' not found"
    cd "$fallback_path"
  fi

  target_ref="$(deletion_target_ref)"
  if [[ $force_worktree -eq 0 ]]; then
    ensure_worktree_safe_to_remove "$path" "$branch" "$target_ref"
  fi

  remove_args=(worktree remove)
  [[ $force_worktree -eq 1 ]] && remove_args+=(--force)
  remove_args+=("$path")
  git_common "${remove_args[@]}"

  if [[ $no_delete_branch -eq 1 ]]; then
    printf 'Removed worktree: %s\n' "$path"
  else
    if branch_deletable "$branch" "$target_ref"; then
      git_common branch -d "$branch"
      printf 'Removed worktree and deleted merged branch: %s\n' "$branch"
    elif [[ $force_branch -eq 1 ]]; then
      git_common branch -D "$branch"
      printf 'Removed worktree and force-deleted branch: %s\n' "$branch"
    else
      printf 'Removed worktree: %s\n' "$path"
      printf 'Kept branch: %s (not merged to %s; use -D to force delete)\n' "$branch" "$target_ref"
    fi
  fi

  if [[ -n "$fallback_path" ]]; then
    emit_cd "$fallback_path"
  fi
}

cmd_squash() {
  local base_branch="$DEFAULT_BRANCH"
  local current=""
  local count=0
  local merge_base=""
  local tmp_file=""
  local subject=""
  local title=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -b|--base)
        [[ $# -ge 2 ]] || die "--base requires a branch"
        base_branch="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: wt squash [--base <branch>]\n'
        return 0
        ;;
      -* )
        die "unknown option: $1"
        ;;
      *)
        die "unexpected argument: $1"
        ;;
    esac
  done

  current="$(current_branch)"
  [[ -n "$current" ]] || die "cannot squash on detached HEAD"
  base_branch="$(resolve_branch_shortcut "$base_branch")"

  [[ "$current" != "$base_branch" ]] || die "base branch and current branch are the same"
  branch_exists_local "$base_branch" || die "base branch not found locally: $base_branch"
  is_worktree_clean "$(pwd -P)" || die "working tree must be clean before squash"

  count="$(git_common rev-list --count "${base_branch}..${current}" 2>/dev/null || printf '0')"
  [[ "$count" =~ ^[0-9]+$ ]] || die "failed to count commits ahead of $base_branch"
  ((count >= 2)) || die "need at least 2 commits ahead of $base_branch to squash"

  merge_base="$(git_common merge-base "$base_branch" "$current" 2>/dev/null || true)"
  [[ -n "$merge_base" ]] || die "no merge-base found between $base_branch and $current"

  tmp_file="$(mktemp)"
  trap 'rm -f "$tmp_file"' RETURN
  subject="squash: ${current} (${count} commits)"
  {
    printf '%s\n\n' "$subject"
    printf 'Squashed commits:\n'
    while IFS= read -r title || [[ -n "$title" ]]; do
      [[ -n "$title" ]] || continue
      printf -- '- %s\n' "$title"
    done < <(git_common log --format=%s --reverse "${base_branch}..${current}")
  } > "$tmp_file"

  git reset --soft "$merge_base"
  git commit --file "$tmp_file"

  printf 'Squashed %d commits on %s into one commit\n' "$count" "$current"
}

usage() {
  cat <<'EOF'
wt - lightweight git worktree helper (bare-in-.git layout)

Usage:
  wt switch [--create] [--base <branch>] [branch]
  wt create <branch> [--base <branch>]
  wt list
  wt remove [branch] [-f|--force-worktree] [-D|--force-branch] [--no-delete-branch]
  wt squash [--base <branch>]
  wt copy-include [--from <branch>] [--to <branch>]
  wt help

Notes:
  - Uses include manifest from default branch worktree (default: .worktreeinclude).
  - switch without branch opens fzf picker (or numeric prompt fallback).
  - remove without branch removes current branch worktree unless on default branch.
  - remove without branch on default branch opens fzf picker (or numeric prompt fallback).
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help)
      usage
      return 0
      ;;
  esac

  init_context

  case "$cmd" in
    switch)
      cmd_switch "$@"
      ;;
    create)
      cmd_create "$@"
      ;;
    list)
      cmd_list "$@"
      ;;
    remove)
      cmd_remove "$@"
      ;;
    squash)
      cmd_squash "$@"
      ;;
    copy-include)
      cmd_copy_include "$@"
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
